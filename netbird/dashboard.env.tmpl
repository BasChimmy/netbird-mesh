# ─────────────────────────────────────────────────────────────
# dashboard.env.tmpl — NetBird dashboard configuration template.
# __NETBIRD_DOMAIN__ is substituted by netbird-up.sh.
# Caddy terminates TLS, so the dashboard serves plain HTTP internally
# and LETSENCRYPT_DOMAIN is set to none.
# ─────────────────────────────────────────────────────────────

# Endpoints (browser-facing, go through Caddy on 443)
NETBIRD_MGMT_API_ENDPOINT=https://__NETBIRD_DOMAIN__
NETBIRD_MGMT_GRPC_API_ENDPOINT=https://__NETBIRD_DOMAIN__

# OIDC — embedded IdP
AUTH_AUDIENCE=netbird-dashboard
AUTH_CLIENT_ID=netbird-dashboard
AUTH_CLIENT_SECRET=
AUTH_AUTHORITY=https://__NETBIRD_DOMAIN__/oauth2
USE_AUTH0=false
AUTH_SUPPORTED_SCOPES=openid profile email groups
AUTH_REDIRECT_URI=/nb-auth
AUTH_SILENT_REDIRECT_URI=/nb-silent-auth

# TLS handled by Caddy reverse proxy
NGINX_SSL_PORT=443
LETSENCRYPT_DOMAIN=none
